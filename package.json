{
  "name": "whop-saas-starter",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "node scripts/db-push.mjs && next dev --turbopack",
    "build": "prisma generate && node scripts/db-push.mjs && next build",
    "start": "next start",
    "lint": "eslint --cache --cache-location .next/cache/eslint/ .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/mdx": "^2.0.13",
    "@whop/checkout": "^0.0.52",
    "fumadocs-core": "^16.7.10",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "^16.7.10",
    "jose": "^6.2.2",
    "whop-kit": "^0.2.0",
    "next": "^16.2.2",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
