    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
