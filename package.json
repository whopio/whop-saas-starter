{
  "name": "whop-saas-starter",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "node scripts/db-push.mjs && next dev --turbopack",
    "build": "prisma generate && node scripts/db-push.mjs && next build",
    "start": "next start",
    "lint": "eslint --cache --cache-location .next/cache/eslint/ .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/mdx": "^2.0.14",
    "@whop/checkout": "^0.2.0",
    "fumadocs-core": "^16.11.1",
    "fumadocs-mdx": "^15.1.0",
    "fumadocs-ui": "^16.11.1",
    "jose": "^6.2.3",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "whop-kit": "^0.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
