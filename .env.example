# =============================================================================
# Whop SaaS Starter - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# See README.md for setup instructions.

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string. Works with Neon, Supabase, Prisma Postgres, and any PostgreSQL provider.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# -----------------------------------------------------------------------------
# Whop OAuth (Required)
# -----------------------------------------------------------------------------
# Create an app at https://whop.com/dashboard/developer
# Your App ID (public, used as OAuth client_id)
NEXT_PUBLIC_WHOP_APP_ID="app_xxxxxxxxx"

# Your App API Key / Client Secret (used for server-side API calls and OAuth token exchange)
WHOP_API_KEY="apik_xxxxxxxxx"

# -----------------------------------------------------------------------------
# Whop Environment (Optional — defaults to production)
# -----------------------------------------------------------------------------
# Set to "sandbox" to use Whop's isolated test environment (sandbox.whop.com).
# Sandbox apps, API keys, plans, and users are completely separate from
# production — create them at https://sandbox.whop.com/dashboard/developer
# and use test cards (e.g. 4242 4242 4242 4242) at checkout.
# Any value other than "sandbox" means production.
# NEXT_PUBLIC_WHOP_ENVIRONMENT="sandbox"

# -----------------------------------------------------------------------------
# Whop Webhooks (Required for payments)
# -----------------------------------------------------------------------------
# Webhook secret from your Whop app's webhook settings
WHOP_WEBHOOK_SECRET="your_webhook_secret_here"

# -----------------------------------------------------------------------------
# Session (Optional — auto-generated if not set)
# -----------------------------------------------------------------------------
# A random 32+ character string used to sign session JWTs.
# If you don't set this, the app auto-generates one and stores it in the database.
# SESSION_SECRET="your-random-secret-here"

# -----------------------------------------------------------------------------
# Whop Plans (Required for paid tiers)
# -----------------------------------------------------------------------------
# Create plans in your Whop dashboard and paste the plan IDs here.
# These are used on the pricing page and to identify plan tiers in webhooks.
# Create a $0 plan in Whop for free users so all customers are managed in Whop.
#
# Env var names are auto-derived from plan keys in lib/constants.ts.
# Pattern: NEXT_PUBLIC_WHOP_{PLAN_KEY}_PLAN_ID / _YEARLY
# Default tiers are free, starter, pro. Add/remove/rename in lib/constants.ts.
NEXT_PUBLIC_WHOP_FREE_PLAN_ID="plan_xxxxxxxxx"
NEXT_PUBLIC_WHOP_STARTER_PLAN_ID="plan_xxxxxxxxx"
NEXT_PUBLIC_WHOP_STARTER_PLAN_ID_YEARLY="plan_xxxxxxxxx"
NEXT_PUBLIC_WHOP_PRO_PLAN_ID="plan_xxxxxxxxx"
NEXT_PUBLIC_WHOP_PRO_PLAN_ID_YEARLY="plan_xxxxxxxxx"

# -----------------------------------------------------------------------------
# Whop Product IDs (Optional — for real-time Whop API access checks)
# -----------------------------------------------------------------------------
# Product IDs are different from plan IDs. Products represent your tiers;
# plans are pricing options (monthly/yearly) within each product.
# Used by checkWhopAccess() / hasWhopAccess() for authoritative access verification.
# WHOP_STARTER_PRODUCT_ID="prod_xxxxxxxxx"
# WHOP_PRO_PRODUCT_ID="prod_xxxxxxxxx"

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Your app's public URL (used for OAuth redirect URLs, OG metadata, and webhooks).
# On Vercel this is auto-detected. Required on other platforms (Railway, Fly, Render, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Integrations (Optional — configure via admin Settings or env vars)
# -----------------------------------------------------------------------------
# Analytics: "posthog", "google", or "plausible"
# ANALYTICS_PROVIDER=""
# ANALYTICS_ID=""

# Transactional email: "resend" or "sendgrid"
# EMAIL_PROVIDER=""
# EMAIL_API_KEY=""
# EMAIL_FROM_ADDRESS="noreply@yourdomain.com"
